# .env.example
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — it contains secrets.

# ── Telegram API credentials ─────────────────────────────────────────────────
# Get these from https://my.telegram.org → "API development tools"
# Log in with your phone number, create an app (any name/platform is fine).
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here

# Your Telegram phone number in E.164 format (country code + number, no spaces)
TELEGRAM_PHONE=+447700900000

# ── Groq API credentials ──────────────────────────────────────────────────────
# Get a free API key from https://console.groq.com → API Keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# Model to use for answering. Default: llama-3.1-8b-instant (fast, free tier).
# Other fast Groq options: llama3-8b-8192, mixtral-8x7b-32768
GROQ_MODEL=llama-3.1-8b-instant

# ── Bot targeting ─────────────────────────────────────────────────────────────
# Numeric ID of the Telegram chat/group/channel to monitor.
# Run: python scripts/list_chats.py to see all your chats and their IDs.
TARGET_CHAT=-1001234567890

# Numeric Telegram user ID of the quizmaster (the person who posts questions).
# We use the numeric ID — NOT @username — because usernames can be changed at
# any time, silently breaking the filter. Numeric IDs are permanent.
# Run: python scripts/list_senders.py to identify the ID from live messages.
QUIZMASTER_USER_ID=987654321
